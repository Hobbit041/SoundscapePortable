{
  "name": "soundscape",
  "version": "1.2.1",
  "description": "Standalone Dungeonscape Mixer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/prebuild.js",
    "prebuild:win": "node scripts/prebuild.js",
    "prebuild:mac": "node scripts/prebuild.js",
    "prebuild:linux": "node scripts/prebuild.js",
    "prebuild:all": "node scripts/prebuild.js",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hobbit041/SoundscapePortable.git"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  },
  "build": {
    "appId": "com.soundscape.app",
    "productName": "Dungeonscape",
    "copyright": "Copyright © 2024",
    "icon": "assets/icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**",
      "translations/**",
      "web-client/**",
      "node_modules/**"
    ],
    "extraResources": [],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dungeonscape"
    },
    "portable": {
      "artifactName": "Dungeonscape-portable.exe"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio"
    }
  }
}
