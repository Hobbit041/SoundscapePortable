{
  "name": "soundscape",
  "version": "1.0.0",
  "description": "Standalone Soundscape Mixer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.soundscape.app",
    "productName": "Soundscape",
    "files": ["main.js", "preload.js", "renderer/**", "assets/**"],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
